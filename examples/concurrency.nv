// ─── Timeout pattern — Phase 2 ───────────────────────────────────────────────
//
// async fn withTimeout<T>(ms: int, op: async fn() → T) → T?
//     let resultCh  = Channel<T>(capacity: 1)
//     let timeoutCh = Channel<unit>(capacity: 1)
//     go
//         let v = await op()
//         await resultCh.send(v)
//     go
//         await sleep(ms)
//         await timeoutCh.send(())
//     select
//         let v = await resultCh.receive(): → v
//         await timeoutCh.receive():         → nil

// ─── Sync demos that run today ────────────────────────────────────────────────
//
// These show the pattern of work distribution that async/await will replace:
// sequential versions of fan-out/fan-in, accumulation, and error propagation.

fn sumRange(lo: int, hi: int) → int
    var total = 0
    var i = lo
    while i <= hi
        total = total + i
        i = i + 1
    → total

fn workerResult(id: int, n: int) → int
    // Simulates "worker id computes n^2"
    → n * n

fn fanOutSum(n: int) → int
    // Simulates collecting results from n workers
    var total = 0
    var i = 0
    while i < n
        total = total + workerResult(i, i)
        i = i + 1
    → total

fn retryCompute(x: int, maxTries: int) → Result<str>
    // Simulates retry logic — succeeds when x > 0
    var tries = 0
    while tries < maxTries
        if x > 0
            → Ok("result: {x * x}")
        tries = tries + 1
    → Err("failed after {maxTries} tries")

fn main()
    println("sum 1..100     = {sumRange(1, 100)}")
    println("sum 1..10      = {sumRange(1, 10)}")

    println("")
    println("fanOutSum(5) = {fanOutSum(5)}")   // 0+1+4+9+16 = 30

    println("")
    match retryCompute(7, 3)
        Ok(res1): → println("compute(7)  = {res1}")
        Err(e1):  → println("compute(7)  failed: {e1}")

    match retryCompute(-1, 3)
        Ok(res2): → println("compute(-1) = {res2}")
        Err(e2):  → println("compute(-1) failed: {e2}")

    println("")
    println("Concurrency demo complete (async features pending Phase 2).")
