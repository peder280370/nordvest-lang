module std.process

@extern(fn: "nv_process_getenv")  pub fn env(name: str) → str?
@extern(fn: "nv_process_setenv")  pub fn setEnv(name: str, value: str)
@extern(fn: "nv_process_exit")    pub fn exit(code: int)
@extern(fn: "nv_process_pid")     pub fn pid() → int
@extern(fn: "nv_process_cwd")     pub fn cwd() → str
@extern(fn: "nv_process_chdir")   pub fn chdir(path: str) → int
@extern(fn: "nv_process_capture") pub fn capture(cmd: str) → str
