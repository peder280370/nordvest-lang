module std.rand

@extern(fn: "nv_rand_seed")  pub fn seed(s: int)
@extern(fn: "nv_rand_init")  pub fn init()
@extern(fn: "nv_rand_float") pub fn float() → float
@extern(fn: "nv_rand_int")   pub fn int(lo: int, hi: int) → int
@extern(fn: "nv_rand_bool")  pub fn bool() → bool
@extern(fn: "nv_rand_next")  pub fn next() → int
